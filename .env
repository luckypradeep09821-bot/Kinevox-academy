# Kinevox Academy — Environment Configuration
# Fill in your values. DO NOT commit this file to git.

# Flask secret key (change in production!)
SECRET_KEY=kinevox-super-secret-key-2024

# JWT expiry in hours
JWT_EXPIRY_HOURS=8

# Server port (Render sets PORT automatically — leave this for local dev)
PORT=5000

# Enable debug mode (set to false in production)
DEBUG=false

# ── Database (PostgreSQL — required) ───────────────────────────────────────
# Free permanent Postgres from Neon (neon.tech) or Supabase (supabase.com)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Email Notifications (via Brevo HTTP API) ───────────────────────────────
# Brevo API key — Brevo dashboard > SMTP & API > API Keys
BREVO_API_KEY=your-brevo-api-key-here

# Sender email — must be verified in Brevo (Senders & IP > Senders)
NOTIFY_FROM_EMAIL=your-email@gmail.com

# Friendly sender name shown in the email
NOTIFY_FROM_NAME=Kinevox Academy

# Recipient email address (where new employee/student alerts are sent)
NOTIFY_EMAIL_TO=your-email@gmail.com
